# Must match the name you register on the Blackout site.
SNAKE_AUTHOR=the sea snake
SNAKE_COLOR=#4488ff

# Checkpoint trained for Blackout rules (restricted_standard, 15x15, 4 snakes).
BATTLE_SNAKE_CHECKPOINT=best_checkpoint/rainbow_20260715_214528_best.pt

# cpu or cuda
TORCH_DEVICE=cpu
FALLBACK_MOVE=up
LOG_LEVEL=INFO

# Optional combat layer at inference (off by default; model already has survival shaping).
SURVIVAL_FILTER=0
SURVIVAL_HUNGER_HEALTH=35
SURVIVAL_STRATEGY=aggressive
