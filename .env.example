# Must match the name you register on the Blackout site.
SNAKE_AUTHOR=the sea snake
SNAKE_COLOR=#4488ff

# Checkpoint trained for Blackout rules (restricted_standard, 15x15, 4 snakes).
BATTLE_SNAKE_CHECKPOINT=best_checkpoint/rainbow_20260704_125842_ep1600.pt

# cpu or cuda
TORCH_DEVICE=cpu
FALLBACK_MOVE=up
LOG_LEVEL=INFO

# Combat play: avoid equal/longer heads; grow then hunt shorter snakes.
SURVIVAL_FILTER=1
SURVIVAL_HUNGER_HEALTH=35
SURVIVAL_STRATEGY=aggressive
